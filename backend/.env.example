# PharmaManager — Backend Environment Variables
# Copiez ce fichier vers .env et ajustez les valeurs.

# ── Django
DEBUG=True
SECRET_KEY=django-insecure-fallback-key-smartholol
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL
DB_NAME=pharma_db
DB_USER=postgres
DB_PASSWORD=postgres
# Laissez DB_HOST vide sur Linux pour utiliser les sockets UNIX (Ident auth)
DB_HOST=localhost
DB_PORT=5432
