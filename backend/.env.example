# PharmaManager — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=votre-secret-key-changez-moi
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=pharma_db
DB_USER=votre_utilisateur_os  # Sur Linux, utilisez votre nom d'utilisateur OS
DB_PASSWORD=votre-mot-de-passe
DB_HOST=  # Sur Linux, laissez vide pour utiliser les sockets UNIX (Ident auth)
DB_PORT=5432
